# Copy to .env.local. All values are dev placeholders until the client grants
# access to her own accounts (see needs.md). Never commit .env.local.

# Session signing — generate with: openssl rand -base64 32
AUTH_SECRET=

# Sanity (use our own free dev project for now)
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_WRITE_TOKEN=

# --- Deferred: filled when the client grants access ---
# Claude API (brochure-not-needed; AI replies in Phase 2)
ANTHROPIC_API_KEY=
# Document storage (Cloudflare R2 / AWS S3)
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
