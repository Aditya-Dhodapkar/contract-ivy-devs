# Copy to .env.local. All values are dev placeholders until the client grants
# access to her own accounts (see needs.md). Never commit .env.local.

# Session signing — generate with: openssl rand -base64 32
AUTH_SECRET=

# --- Backend toggle ---
# true  → JSON-file backend + local public/uploads (default for dev)
# false → Supabase Postgres + Supabase Storage (production)
USE_DEV_DATA=true

# --- Supabase (only needed when USE_DEV_DATA=false) ---
# Get from Supabase dashboard → Project Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=property-photos

# --- Deferred: filled when the client grants access ---
# Claude API (brochure copy polish + Phase 2 AI replies)
ANTHROPIC_API_KEY=

# Mapbox (brochure locality map). If unset, the brochure falls back to a free
# OpenStreetMap static-map embed. Get a token at https://account.mapbox.com.
MAPBOX_TOKEN=
# Optional: a custom style designed in Mapbox Studio (https://studio.mapbox.com).
# Form: mapbox://styles/{username}/{style_id}. If unset, defaults to
# mapbox/light-v11 (built-in cream/grey palette).
MAPBOX_STYLE_URL=

# --- Feedback button → GitHub Issues ---
# When set, the "Send feedback" button in the header relays bug reports,
# feature requests, and questions to GitHub Issues on the repo below. The
# token is a fine-grained PAT with permissions on that ONE repo:
#   - Issues: read/write     (to create issues)
#   - Contents: read/write   (to commit user-uploaded screenshots into
#                             .github/feedback-images/)
# If either var is empty, the API returns 503 and the modal shows a setup
# hint — feature stays gracefully off.
# Create the PAT at https://github.com/settings/personal-access-tokens.
GITHUB_FEEDBACK_TOKEN=
GITHUB_FEEDBACK_REPO=Aditya-Dhodapkar/contract-ivy-devs
